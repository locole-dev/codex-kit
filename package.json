{
  "name": "@locole/locole-skills",
  "version": "0.2.1",
  "description": "Bootstrap the Locole .agent toolkit and .codex/skills into a project for team-shared Cursor/Codex workflows.",
  "author": "Locole",
  "keywords": [
    "codex",
    "cursor",
    "agent",
    "skills",
    "workflow",
    "toolkit"
  ],
  "bin": {
    "locole-skills": "bin/locole-skills.js"
  },
  "scripts": {
    "lint": "node --check bin/locole-skills.js && node --check tests/locole-skills.test.js",
    "test": "node --test tests/locole-skills.test.js",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run lint && npm test && npm run pack:check"
  },
  "files": [
    "bin",
    ".agent",
    ".codex/skills",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
